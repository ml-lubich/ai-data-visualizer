# Anthropic API key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (optional, default: claude-3-5-sonnet-20241022)
# Options: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022, claude-3-opus-20240229
MODEL=claude-3-5-sonnet-20241022

# Server port (optional, default: 5000)
PORT=5000

# Enable Flask debug mode — set to 1 ONLY in local development, never in production
FLASK_DEBUG=0
