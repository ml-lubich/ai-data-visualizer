{
  "env": {
    "node": true,
    "es2022": true,
    "browser": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error"
  },
  "overrides": [
    {
      "files": ["public/js/**/*.js"],
      "env": { "browser": true },
      "globals": { "Bokeh": "readonly" }
    }
  ]
}
